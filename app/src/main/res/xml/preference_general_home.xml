<?xml version="1.0" encoding="utf-8"?>
<!--
  ~ WaEnhancer General Home Preferences
  ~
  ~ This screen contains the theme mode selector and other general settings.
  ~ Theme selection options:
  ~ - Follow System (0): Uses Android system theme setting
  ~ - Dark Theme On (1): Forces dark theme
  ~ - Dark Theme Off (2): Forces light theme (uses light Material3 theme)
  ~
  ~ The theme mode preference triggers App.setThemeMode() via BasePreferenceFragment.
  -->
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <PreferenceCategory
        app:iconSpaceReserved="false"
        app:title="@string/general">

        <!--
          ~ Material3 Theme Mode Selection
          ~ Controls the app's dark/light theme mode:
          ~ - Mode 0 (Follow System): Uses AppCompatDelegate.MODE_NIGHT_FOLLOW_SYSTEM
          ~ - Mode 1 (Dark On): Uses AppCompatDelegate.MODE_NIGHT_YES
          ~ - Mode 2 (Dark Off): Uses AppCompatDelegate.MODE_NIGHT_NO
          ~
          ~ On Android 12+, Material You dynamic colors are applied regardless of mode.
          ~ On Android 16+, predictive back animations and enhanced theme transitions.
          -->
        <ListPreference
            app:entries="@array/thememode_entries"
            app:entryValues="@array/thememode_values"
            app:key="thememode"
            app:summary="%s"
            app:title="@string/theme_mode" />
            
        <rikka.material.preference.MaterialSwitchPreference
            app:key="update_check"
            app:defaultValue="true"
            app:summary="@string/update_check_sum"
            app:title="@string/update_check" />

        <rikka.material.preference.MaterialSwitchPreference
            app:defaultValue="false"
            app:key="disable_expiration"
            app:summary="Deactivates the expired version of WhatsApp, (Note: Manual Disable to update WhatsApp on the Play Store or mark the Play Store on LSposed)"
            app:title="Disable WhatsApp Expiration" />

        <rikka.material.preference.MaterialSwitchPreference
            app:key="lite_mode"
            app:summary="@string/lite_mode_sum"
            app:title="@string/lite_mode" />

        <rikka.material.preference.MaterialSwitchPreference
            app:key="force_english"
            app:title="@string/force_english" />

        <rikka.material.preference.MaterialSwitchPreference
            app:defaultValue="true"
            app:key="enablelogs"
            app:title="@string/verbose_logs" />

        <rikka.material.preference.MaterialSwitchPreference
            app:defaultValue="false"
            app:key="bypass_version_check"
            app:summary="@string/disable_version_check_sum"
            app:title="@string/disable_version_check" />

        <rikka.material.preference.MaterialSwitchPreference
            android:summary="@string/bootloader_spoofer_sum"
            android:title="@string/bootloader_spoofer"
            app:key="bootloader_spoofer" />

        <rikka.material.preference.MaterialSwitchPreference
            android:summary="@string/bootloader_spoofer_sum"
            android:title="Enable Custom KeyBox"
            app:key="bootloader_spoofer_custom" />

        <com.wmods.wppenhacer.preference.FileReaderPreference
            android:key="bootloader_spoofer_xml"
            android:dependency="bootloader_spoofer_custom"
            android:title="Use Custom keybox.xml file"
            android:summary="No file selected" />

        <rikka.material.preference.MaterialSwitchPreference
            app:key="ampm"
            app:title="@string/ampm" />

        <rikka.material.preference.MaterialSwitchPreference
            app:key="segundos"
            app:summary="@string/segundosnahora_sum"
            app:title="@string/segundosnahora" />

        <EditTextPreference
            app:iconSpaceReserved="false"
            app:key="secondstotime"
            app:summary="@string/textonahora_sum"
            app:title="@string/textonahora" />

        <rikka.material.preference.MaterialSwitchPreference
            app:key="tasker"
            app:summary="@string/enable_tasker_automation_sum"
            app:title="@string/enable_tasker_automation" />

    </PreferenceCategory>

</PreferenceScreen>