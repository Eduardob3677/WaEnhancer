<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?colorSurface"
    app:consumeSystemWindowsInsets="@integer/internal_fragment_insets"
    app:edgeToEdge="true"
    app:fitsSystemWindowsInsets="@integer/internal_fragment_insets">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:fitsSystemWindowsInsets="@integer/internal_fragment_bottom_insets"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        tools:ignore="MissingPrefix">

        <rikka.widget.borderview.BorderNestedScrollView
            android:id="@+id/nestedScrollView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="none"
            android:clipToPadding="false"
            app:borderBottomVisibility="never"
            app:borderTopDrawable="@null"
            app:borderTopVisibility="whenTop">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:animateLayoutChanges="true"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/screen_padding_horizontal"
                android:paddingTop="@dimen/screen_padding_vertical"
                android:paddingBottom="32dp"
                tools:context=".ui.activity.MainActivity">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/status"
                    style="@style/Widget.WaEnhancer.StatusCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="?colorPrimaryContainer"
                    tools:targetApi="p">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="@dimen/status_card_padding_vertical"
                        android:paddingHorizontal="@dimen/status_card_padding_horizontal">

                        <ImageView
                            android:id="@+id/status_icon"
                            android:layout_width="@dimen/icon_size_status"
                            android:layout_height="@dimen/icon_size_status"
                            android:tint="?colorOnPrimaryContainer"
                            app:srcCompat="@drawable/ic_round_check_circle_24"
                            tools:ignore="ContentDescription" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="20dp"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/status_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/module_enabled"
                                android:textAppearance="?textAppearanceTitleMedium"
                                android:textColor="?colorOnPrimaryContainer" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/status_summary"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text=""
                                android:textAppearance="?textAppearanceBodySmall"
                                android:textColor="?colorOnPrimaryContainer"
                                android:alpha="0.9" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/status2"
                    style="@style/Widget.WaEnhancer.StatusCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:cardBackgroundColor="?colorSecondaryContainer"
                    tools:targetApi="p">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="20dp"
                        android:paddingHorizontal="@dimen/status_card_padding_horizontal">

                        <ImageView
                            android:id="@+id/status_icon2"
                            android:layout_width="@dimen/icon_size_large"
                            android:layout_height="@dimen/icon_size_large"
                            android:tint="?colorOnSecondaryContainer"
                            app:srcCompat="@drawable/ic_round_check_circle_24"
                            tools:ignore="ContentDescription" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="12dp"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/status_title2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/whatsapp_in_background"
                                android:textAppearance="?textAppearanceTitleSmall"
                                android:textColor="?colorOnSecondaryContainer" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/status_summary1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text=""
                                android:textAppearance="?textAppearanceBodySmall"
                                android:textColor="?colorOnSecondaryContainer"
                                android:alpha="0.9" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/reboot_btn"
                            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:icon="@drawable/ic_reload"
                            app:iconTint="?colorOnSecondaryContainer"
                            app:shapeAppearance="@style/ShapeAppearance.WaEnhancer.Pill"
                            android:contentDescription="@string/restart_whatsapp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/status3"
                    style="@style/Widget.WaEnhancer.StatusCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardBackgroundColor="?colorTertiaryContainer"
                    tools:targetApi="p">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="20dp"
                        android:paddingHorizontal="@dimen/status_card_padding_horizontal">

                        <ImageView
                            android:id="@+id/status_icon3"
                            android:layout_width="@dimen/icon_size_large"
                            android:layout_height="@dimen/icon_size_large"
                            android:tint="?colorOnTertiaryContainer"
                            app:srcCompat="@drawable/ic_round_check_circle_24"
                            tools:ignore="ContentDescription" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="12dp"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/status_title3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/business_in_background"
                                android:textAppearance="?textAppearanceTitleSmall"
                                android:textColor="?colorOnTertiaryContainer" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/status_summary3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text=""
                                android:textAppearance="?textAppearanceBodySmall"
                                android:textColor="?colorOnTertiaryContainer"
                                android:alpha="0.9" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/reboot_btn2"
                            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            app:icon="@drawable/ic_reload"
                            app:iconTint="?colorOnTertiaryContainer"
                            app:shapeAppearance="@style/ShapeAppearance.WaEnhancer.Pill"
                            android:contentDescription="@string/restart_whatsapp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>


                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/developer_warning_card"
                    style="@style/Widget.WaEnhancer.InfoCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="?colorErrorContainer"
                    app:strokeColor="?colorError"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Developer Warning"
                            android:textAppearance="?textAppearanceTitleSmall"
                            android:textColor="?colorOnErrorContainer" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Warning summary placeholder"
                            android:textAppearance="?textAppearanceBodySmall"
                            android:textColor="?colorOnErrorContainer"
                            android:lineSpacingMultiplier="1.3" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/info_card"
                    style="@style/Widget.WaEnhancer.InfoCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <com.google.android.material.textview.MaterialTextView
                            style="@style/DeviceInfoDialogLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/android_version" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/sdk"
                            style="@style/DeviceInfoDialogValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="" />

                        <com.google.android.material.textview.MaterialTextView
                            style="@style/DeviceInfoDialogLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/device_name" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/device_name"
                            style="@style/DeviceInfoDialogValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="" />

                        <com.google.android.material.textview.MaterialTextView
                            style="@style/DeviceInfoDialogLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/device_model" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/model_name"
                            style="@style/DeviceInfoDialogValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/list_wpp_title"
                            style="@style/DeviceInfoDialogLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/list_wpp" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/list_wpp"
                            style="@style/DeviceInfoDialogValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:gravity="center_vertical" />

                        <com.google.android.material.textview.MaterialTextView
                            style="@style/DeviceInfoDialogLabel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/list_business" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/list_business"
                            style="@style/DeviceInfoDialogValue"
                            android:layout_width="match_parent"
                            android:text=""
                            android:layout_height="wrap_content"
                            android:paddingBottom="0dp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    style="@style/Widget.WaEnhancer.InfoCard"
                    android:layout_width="match_parent"
                    android:layout_marginTop="16dp"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:padding="@dimen/card_padding"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textAlignment="center"
                            android:text="@string/backup_settings"
                            android:textAppearance="?textAppearanceTitleSmall"
                            android:textColor="?colorOnSurface"
                            android:paddingBottom="20dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/importBtn"
                                style="@style/Widget.WaEnhancer.Button.Tonal"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:layout_weight="1"
                                android:text="@string/import_settings" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/exportBtn"
                                style="@style/Widget.WaEnhancer.Button.Tonal"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:text="@string/export_settings" />
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/resetBtn"
                            style="@style/Widget.WaEnhancer.Button.Outlined"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="@string/reset_settings" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </rikka.widget.borderview.BorderNestedScrollView>
    </FrameLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
