<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardView"
                style="@style/WaEnhancer.CardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="?colorPrimaryContainer"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textAppearance="?textAppearanceHeadlineMedium"
                        android:textColor="?colorOnPrimaryContainer" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvDevName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/developer"
                        android:textAppearance="?textAppearanceBodyLarge"
                        android:textColor="?colorOnPrimaryContainer"
                        android:alpha="0.8" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvMainFeatures"
                style="@style/WaEnhancer.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvFeaturesSummary"
                style="@style/WaEnhancer.BodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="16dp"
                android:text="@string/about_info" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvInstallation"
                style="@style/WaEnhancer.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/installation" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvInstallationSteps"
                style="@style/WaEnhancer.BodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="24dp"
                android:text="@string/installation_desc" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTelegram"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/go_to_telegram"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_telegram"
                app:iconGravity="start"
                app:iconPadding="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGithub"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/go_to_github"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_github"
                app:iconGravity="start"
                app:iconPadding="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDonate"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="@string/donate"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_donate"
                app:iconGravity="start"
                app:iconPadding="12dp" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvSupport"
                style="@style/WaEnhancer.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/support" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvSupportDetails"
                style="@style/WaEnhancer.BodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="16dp"
                android:text="@string/support_desc" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvLicense"
                style="@style/WaEnhancer.SectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/license" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvLicenseDetails"
                style="@style/WaEnhancer.BodyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="16dp"
                android:text="@string/license_desc" />

        </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
